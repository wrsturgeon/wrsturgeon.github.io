---
layout: null
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title | xml_escape }}</title>
  <subtitle>{{ site.description | xml_escape }}</subtitle>
  <link href="{{ '/feed.xml' | absolute_url }}" rel="self"/>
  <link href="{{ '/' | absolute_url }}"/>
  <updated>{% if site.posts.first %}{{ site.posts.first.date | date_to_xmlschema }}{% else %}{{ site.time | date_to_xmlschema }}{% endif %}</updated>
  <id>{{ '/' | absolute_url }}</id>
  <author>
    <name>{{ site.title | xml_escape }}</name>
  </author>
  {% for post in site.posts %}
  <entry>
    <title>{{ post.title | xml_escape }}</title>
    <link href="{{ post.url | absolute_url }}"/>
    <id>{{ post.url | absolute_url }}</id>
    <updated>{{ post.date | date_to_xmlschema }}</updated>
    <summary>{{ post.excerpt | strip_html | strip_newlines | xml_escape }}</summary>
    <content type="html">{{ post.content | markdownify | xml_escape }}</content>
  </entry>
  {% endfor %}
</feed>
